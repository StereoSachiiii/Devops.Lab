{
  "name": "devops-learning-platform",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker-compose --profile default up -d --force-recreate && npx turbo run dev",
    "dev:web": "npm run dev --workspace=apps/web",
    "build:web": "npm run build --workspace=apps/web",
    "lint": "npm run lint --workspaces",
    "setup:firecracker": "bash scripts/setup-kata.sh",
    "stop": "docker compose -p rootcause --profile default down -v && pkill -9 -f 'ts-node' || true && pkill -9 -f 'ts-node-dev' || true"
  },
  "devDependencies": {
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.9",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0"
  }
}
