// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
  output = "../../../node_modules/.prisma/client"
}



datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?   // Optional for OAuth users
  role          Role      @default(LEARNER)
  xp            Int       @default(0)
  
  // Auth & Verification
  emailVerified DateTime?
  githubId      String?   @unique
  googleId      String?   @unique
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?  
  submissions   Submission[]
  completions   Completion[]
  sessions      LabSession[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}


model Completion {
  userId    String
  nodeId    String
  user      User     @relation(fields: [userId], references: [id])
  node      Node     @relation(fields: [nodeId], references: [id])
  createdAt DateTime @default(now())

  @@id([userId, nodeId])
}


model Challenge {
  id          String    @id @default(cuid())
  title       String
  description String
  difficulty  Difficulty
  category    Category
  tags        String[]
  xp          Int
  dockerImage    String    // e.g. "ghcr.io/devops-platform/nginx-basics:latest"
  templateCode   String?
  editorLanguage String    @default("plaintext")
  moduleId       String?
  module      Module?   @relation(fields: [moduleId], references: [id])
  submissions Submission[]
  sessions    LabSession[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model LabSession {
  id          String    @id @default(cuid()) // equals the sessionId in Redis/sandbox
  userId      String
  challengeId String
  user        User      @relation(fields: [userId], references: [id])
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  status      SessionStatus @default(ACTIVE)
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  TERMINATED
}

model LearningPath {
  id          String    @id @default(cuid())
  title       String
  description String
  slug        String    @unique
  modules     Module[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Module {
  id             String         @id @default(cuid())
  title          String
  description    String
  order          Int
  pathId         String
  path           LearningPath   @relation(fields: [pathId], references: [id])
  challenges     Challenge[]
  incidents      IncidentMetadata[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model IncidentMetadata {
  id          String    @id @default(cuid())
  title       String
  description String
  scenario    String    // The "broken spec" for simulation
  postMortem  String    // The explanatory material
  difficulty  Difficulty
  xp          Int
  moduleId    String
  module      Module    @relation(fields: [moduleId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Submission {
  id          String    @id @default(cuid())
  code        String
  status      SubmissionStatus @default(PENDING)
  result      Json?
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  createdAt   DateTime  @default(now())
}

enum NodeType {
  CONCEPT
  SCENARIO
  QUIZ
}

model Node {
  id          String    @id @default(cuid())
  type        NodeType
  title       String
  description String
  metadata    Json?
  createdAt   DateTime  @default(now())
  
  // Relations
  outgoing    Edge[]       @relation("from")
  incoming    Edge[]       @relation("to")
  completions Completion[]
}


model Edge {
  fromId String
  toId   String
  from   Node   @relation("from", fields: [fromId], references: [id])
  to     Node   @relation("to", fields: [toId], references: [id])

  @@id([fromId, toId])
}

enum Role {
  GUEST
  LEARNER
  CONTRIBUTOR
  ADMIN
}

enum Difficulty {
  JUNIOR
  MID
  SENIOR
}

enum Category {
  KUBERNETES
  DOCKER
  CICD
  TERRAFORM
  BASH
  SECURITY
  MONITORING
}

enum SubmissionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model SecurityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // e.g., "REGISTER", "LOGIN_SUCCESS", "LOGIN_FAILED", "LOCKOUT", "LOGOUT"
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model OutboxEvent {
  id        String   @id @default(cuid())
  eventType String   // e.g., "UserRegisteredEvent", "EmailVerificationRequestedEvent"
  payload   Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
}

