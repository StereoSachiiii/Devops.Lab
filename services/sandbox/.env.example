HTTP_PORT=3001
REDIS_URL=redis://localhost:6379/1
DATABASE_URL=postgresql://user:password@localhost:5432/devops_sandbox
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=sandbox-worker
KAFKA_GROUP_ID=sandbox-sessions
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
SESSION_TTL_MINS=60
MAX_MEMORY_MB=512
MAX_CPUS=1.0
ENCRYPTION_KEY=l767toOlhpU4iNzVso9EMse2boXfbbmejPHUSiSjab0=
RABBITMQ_URL=amqp://localhost:5672

# Sandbox Provider: docker (default) | gvisor | kata | flintlock
# - docker:    Standard Docker containers. Works on any host with Docker installed.
# - gvisor:    Requires 'runsc' runtime registered in Docker daemon (install gVisor on host).
# - kata:      Requires 'kata-fc' or 'kata-qemu' runtime registered in Docker daemon.
# - flintlock: Requires a running Flintlock gRPC daemon on the host (bare-metal only).
SANDBOX_PROVIDER=docker

# Flintlock provider settings (only required when SANDBOX_PROVIDER=flintlock)
FLINTLOCK_ADDRESS=localhost:9090
# Path to the SSH private key used to authenticate into Flintlock microVMs.
# Generate with: ssh-keygen -t ed25519 -f ~/.ssh/flintlock_sandbox -N ""
# The corresponding public key must be injected into your microVM cloud-init user-data.
FLINTLOCK_SSH_KEY_PATH=/root/.ssh/flintlock_sandbox
