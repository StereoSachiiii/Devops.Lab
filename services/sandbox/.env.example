# Sandbox Service — Environment Variables
# Copy to .env and fill in values for local development.

# ── HTTP Server ────────────────────────────────────────────────────────────────
# The WebSocket terminal endpoint and validate endpoint listen here.
HTTP_PORT=8090

# ── Postgres ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/devops_platform

# ── Redis (session store: sessionID → containerID) ─────────────────────────────
REDIS_URL=redis://localhost:6379

# ── RabbitMQ ───────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672
SESSION_QUEUE=sandbox.sessions

# ── Kafka (Redpanda) ───────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=sandbox-worker

# ── JWT ────────────────────────────────────────────────────────────────────────
# Must match the JWT_SECRET used by the auth-service.
# ── Session Limits ─────────────────────────────────────────────────────────────
SESSION_TTL_MINS=60       # containers are force-killed after this many minutes

# ── Docker Sandbox Resource Limits ─────────────────────────────────────────────
MAX_MEMORY_MB=512         # per container
MAX_CPUS=1.0              # per container (1.0 = one full core)

# ── Docker Network Mode ────────────────────────────────────────────────────────
# "none"   → no network access (production)
# "bridge" → standard Docker networking (local debugging only)
DOCKER_NETWORK_MODE=none

JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA0fceR0dR3hHLtwcLnaUo\n9BlB70K8tkV7avou+rtCk8Jo+zI24oSf04WPMRYd0FtRdPyY9G3fb7fH7sLOOtOw\n6sBGbKN9C/sf3o83ycEHV0RpqeLGpqUbM/4Itr5j5y+9n4EwNESSZnTM73UJua+8\nKjTOpKydqr8eWpu5Sm6ITC7d5EY1DUY9ubF4qQhKQ8ziAOrIghXwFu5oemHYkff0\nS0wRsUVkIGcLgkpcynroJCx7pMBGg5rbysMz6zPnANcug4NlCchcJZVu0lKGSS9z\nzN7+rKo4HyvYMPKGDkq9pSUCqGfDaEAGr73mdFfPb/wgY+p5/73enHJJzELilykE\nGQIDAQAB\n-----END PUBLIC KEY-----\n"
