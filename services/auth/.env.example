# Auth Service — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ───────────────────────────────────────────────────────────────────
# Neon serverless Postgres connection string
DATABASE_URL=postgresql://user:password@localhost:5432/devops_auth

# ── JWT ────────────────────────────────────────────────────────────────────────
# Change this to a long random secret in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret

# ── Service URLs ───────────────────────────────────────────────────────────────
# The public URL this auth service is reachable at (used for OAuth callback URIs)
BASE_URL=http://localhost:3002
# The Next.js frontend URL (users are redirected here after OAuth)
FRONTEND_URL=http://localhost:3000

# ── Kafka (Redpanda) ───────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=auth-service

# ── GitHub OAuth ───────────────────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
# Callback URL: http://localhost:3002/login/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3002/login/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
